rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Clients only read approved, active opportunities.
    // Pending/rejected review data is available through admin Cloud Functions.
    match /opportunities/{oppId} {
      allow read: if resource.data.is_approved == true && resource.data.is_active == true;
      allow write: if false;
    }

    // User records are private to their owner. Users cannot grant themselves admin/public roles.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['role', 'is_admin', 'admin', 'is_public']);
      allow update: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_admin', 'admin', 'is_public']);
      allow delete: if false;

      match /applications/{oppId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /matches/{oppId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}

# LLM provider: anthropic, openai, gemini, or openai_compatible.
# openai_compatible is for local/self-hosted Gemma via Ollama, llama.cpp, vLLM, etc.
LLM_PROVIDER=anthropic
LLM_MODEL=
LLM_ANALYST_MODEL=
LLM_ESSAY_MODEL=

LLM_API_KEY=your-active-provider-key-or-local
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
LLM_BASE_URL=http://127.0.0.1:11434/v1

GOOGLE_SEARCH_API_KEY=your-google-api-key...
GOOGLE_SEARCH_CX=your-search-engine-id...

# WhatsApp Meta Cloud API
WHATSAPP_TOKEN=EAAB...
WHATSAPP_PHONE_ID=1234567890

# Admins (comma separated emails)
ADMIN_EMAILS=ceo@opptrack.com,admin@opptrack.com
